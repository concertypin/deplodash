{
    "name": "@deplodash/web",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "license": "Apache-2.0",
    "author": {
        "name": "concertypin",
        "url": "https://github.com/concertypin"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "format": "prettier --write . --cache --list-different",
        "typecheck": "svelte-check --tsconfig ./tsconfig.app.json --fail-on-warnings",
        "lint": "pnpm run typecheck && pnpm run lint:oxlint --fix && pnpm run lint:eslint --fix",
        "check": "pnpm run format && pnpm run typecheck && pnpm run lint:oxlint && pnpm run lint:eslint",
        "lint:check": "pnpm run typecheck && pnpm run lint:oxlint && pnpm run lint:eslint",
        "lint:oxlint": "oxlint . --type-aware --type-check --report-unused-disable-directives-severity=error",
        "lint:eslint": "eslint . --cache",
        "preview": "vite preview",
        "test": "vitest run"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@deplodash/api": "workspace:*",
        "daisyui": "^5.6.18",
        "hono": "^4.12.27",
        "svelte": "^5.55.1",
        "svelte-spa-router": "^5.1.1",
        "tailwindcss": "^4.2.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tailwindcss/postcss": "^4.2.2",
        "@tailwindcss/vite": "^4.3.2",
        "@types/node": "^25.5.0",
        "@typescript/native-preview": "7.0.0-dev.20260707.2",
        "@vitest/browser-playwright": "^4.1.2",
        "@vitest/coverage-v8": "^4.1.2",
        "cross-env": "^10.1.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-oxlint": "^1.58.0",
        "eslint-plugin-svelte": "^3.16.0",
        "globals": "^17.4.0",
        "oxlint": "^1.58.0",
        "oxlint-tsgolint": "^0.19.0",
        "phosphor-svelte": "^3.1.0",
        "playwright": "^1.59.1",
        "postcss": "^8.5.8",
        "prettier": "^3.8.1",
        "svelte-check": "^4.7.2",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.3",
        "vitest": "^4.1.2",
        "vitest-browser-svelte": "^2.1.0"
    },
    "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
