{
    "name": "deplodash",
    "type": "module",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "dev": "concurrently --names API,WEB --prefix-colors blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
        "dev:api": "pnpm --filter @deplodash/api dev",
        "dev:web": "pnpm --filter @deplodash/web dev",
        "check": "pnpm --parallel -r check",
        "build": "pnpm --parallel -r build",
        "build:api": "pnpm --filter @deplodash/api build",
        "build:web": "pnpm --filter @deplodash/web build",
        "test": "pnpm --parallel -r test",
        "lint": "pnpm --parallel -r lint",
        "format": "pnpm --parallel -r format"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "concurrently": "^10.0.3",
        "oxlint": "^1.74.0",
        "simple-git-hooks": "^2.13.1"
    },
    "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
}